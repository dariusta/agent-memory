# Obsidian Wiki configuration — copy to .env and edit paths for your machine.
# Then symlink it so any project can find it:
#   ln -sf "$PWD/.env" ~/.obsidian-wiki/config

OBSIDIAN_VAULT_PATH=/absolute/path/to/this/vault
OBSIDIAN_WIKI_REPO=/absolute/path/to/this/vault

# Link style for internal references: "wikilink" (Obsidian-native [[Page]]) or "markdown"
OBSIDIAN_LINK_FORMAT=wikilink

# --- Optional: QMD semantic search index (leave unset to use grep-based retrieval) ---
# QMD_WIKI_COLLECTION=knowledge-base-wiki
# QMD_PAPERS_COLLECTION=knowledge-base-papers
# QMD_TRANSPORT=mcp
# QMD_CLI=qmd
# QMD_CLI_SEARCH_MODE=quality
